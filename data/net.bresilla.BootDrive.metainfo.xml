<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>net.bresilla.BootDrive</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <name>BootDrive</name>
  <summary>Expose a disk image as a bootable USB drive</summary>

  <description>
    <p>
      BootDrive turns your postmarketOS phone into a bootable USB drive. Select
      one ISO or raw disk image and expose it to a connected computer as a
      bootable USB CD-ROM or USB disk, then eject to return to normal USB
      behaviour.
    </p>
    <p>
      BootDrive is deliberately small: it exposes exactly one image at a time,
      always read-only, and relies on a privileged system helper for the
      low-level USB gadget work so the app itself stays sandboxed.
    </p>
  </description>

  <launchable type="desktop-id">net.bresilla.BootDrive.desktop</launchable>

  <recommends>
    <control>touch</control>
    <display_length compare="ge">360</display_length>
  </recommends>
  <supports>
    <control>keyboard</control>
    <control>pointing</control>
  </supports>

  <categories>
    <category>System</category>
    <category>Utility</category>
  </categories>

  <content_rating type="oars-1.1"/>

  <branding>
    <color type="primary" scheme_preference="light">#c3e5ea</color>
    <color type="primary" scheme_preference="dark">#0b6f7d</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/bresilla/bootdrive/main/data/screenshots/mount.png</image>
      <caption>Connected as a bootable USB drive</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/bresilla/bootdrive/main/data/screenshots/choose.png</image>
      <caption>Pick an image from your library</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/bresilla/bootdrive/main/data/screenshots/images.png</image>
      <caption>Manage your image library</caption>
    </screenshot>
  </screenshots>

  <url type="homepage">https://github.com/bresilla/bootdrive</url>
  <url type="bugtracker">https://github.com/bresilla/bootdrive/issues</url>
  <url type="vcs-browser">https://github.com/bresilla/bootdrive</url>

  <developer id="net.bresilla">
    <name>Trim Bresilla</name>
  </developer>

  <releases>
    <release version="0.2.0" date="2026-07-19">
      <description>
        <p>Adds a Download tab: browse distros from osinfo-db and fetch an ISO straight into your library.</p>
      </description>
    </release>
    <release version="0.1.0" date="2026-07-18">
      <description>
        <p>First release: select one image and expose it as a bootable USB drive.</p>
      </description>
    </release>
  </releases>
</component>
