# Maintainer: Kushtrim Bresilla <kushtrimbresilla@gmail.com>
pkgname=bootdrived
pkgver=0.1.0
pkgrel=0
pkgdesc="Privileged BootDrive backend + CLI that exposes a disk image as a bootable USB drive"
url="https://github.com/bresilla/bootdrive"
arch="all"
license="MIT"
# Runtime: system bus, PolicyKit, and the normal USB gadget owner.
depends="dbus polkit usb-signaller"
makedepends="cargo"
install="$pkgname.post-install"
subpackages=""
source="
	bootdrived.service
	bootdrived.openrc
	net.bresilla.BootDrive1.service
	net.bresilla.BootDrive1.conf
	net.bresilla.BootDrive1.policy
"
options="!check"  # integration tests require USB gadget hardware

# Built from the workspace at the repository root. When packaging from a release
# tarball, point builddir at the unpacked source instead.
builddir="$srcdir/.."

build() {
	cd "$builddir"
	cargo build --release --frozen \
		--package bootdrived --bin bootdrived \
		--package bootdrive-cli --bin bootdrive
}

package() {
	cd "$builddir"

	# Backend + CLI binaries.
	install -Dm755 target/release/bootdrived "$pkgdir"/usr/libexec/bootdrived
	install -Dm755 target/release/bootdrive  "$pkgdir"/usr/bin/bootdrive

	# Service units: systemd (primary) + OpenRC (fallback).
	install -Dm644 "$srcdir"/bootdrived.service \
		"$pkgdir"/usr/lib/systemd/system/bootdrived.service
	install -Dm755 "$srcdir"/bootdrived.openrc \
		"$pkgdir"/etc/init.d/bootdrived

	# System D-Bus activation + policy.
	install -Dm644 "$srcdir"/net.bresilla.BootDrive1.service \
		"$pkgdir"/usr/share/dbus-1/system-services/net.bresilla.BootDrive1.service
	install -Dm644 "$srcdir"/net.bresilla.BootDrive1.conf \
		"$pkgdir"/usr/share/dbus-1/system.d/net.bresilla.BootDrive1.conf

	# PolicyKit action.
	install -Dm644 "$srcdir"/net.bresilla.BootDrive1.policy \
		"$pkgdir"/usr/share/polkit-1/actions/net.bresilla.BootDrive1.policy
}

sha512sums="SKIP  bootdrived.service
SKIP  bootdrived.openrc
SKIP  net.bresilla.BootDrive1.service
SKIP  net.bresilla.BootDrive1.conf
SKIP  net.bresilla.BootDrive1.policy"
